# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=paceforge
POSTGRES_PASSWORD=paceforge
POSTGRES_DB=paceforge

# ── Backend ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://paceforge:paceforge@localhost:5432/paceforge
SECRET_KEY=change-me-to-a-random-32-char-string
APP_PASSWORD=your-gym-password

# ── OpenRouter AI ────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
# Primary model — any OpenRouter model slug works here
AI_MODEL=anthropic/claude-sonnet-4-5
# Fallback model if primary fails or rate-limits
AI_FALLBACK_MODEL=openai/gpt-4o-mini

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
